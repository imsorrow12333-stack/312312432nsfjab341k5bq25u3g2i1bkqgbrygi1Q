<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Creepy Talking Ben</title>
<style>
    body {
        background: #111;
        color: white;
        font-family: Arial, sans-serif;
        text-align: center;
        margin-top: 50px;
    }

    #ben {
        font-size: 120px;
    }

    #chat {
        width: 300px;
        padding: 10px;
    }

    #response {
        margin-top: 20px;
        font-size: 24px;
        color: #ff6666;
    }
</style>
</head>
<body>

<div id="ben">🐶</div>

<h1>Talking Ben?</h1>

<input id="chat" placeholder="Say something to Ben...">
<button onclick="talkToBen()">Talk</button>

<div id="response">Ben is listening...</div>

<script>
let talks = 0;

const normal = [
    "Yes.",
    "No.",
    "Ho ho ho.",
    "Okay.",
    "Maybe."
];

const creepy = [
    "I heard that before.",
    "The walls remember.",
    "Someone was standing behind you earlier.",
    "The clock stopped at 3:17 again.",
    "Why is it so quiet where you are?",
    "Don't look at the window.",
    "I think something just moved.",
    "Did you hear that too?"
];

function talkToBen() {
    talks++;

    let response;

    if (talks < 5) {
        response = normal[Math.floor(Math.random() * normal.length)];
    } else {
        response = creepy[Math.floor(Math.random() * creepy.length)];
    }

    document.getElementById("response").textContent = "Ben: " + response;

    // Optional text-to-speech
    const speech = new SpeechSynthesisUtterance(response);
    speech.pitch = 0.8;
    speech.rate = 0.9;
    window.speechSynthesis.speak(speech);
}
</script>

</body>
</html>
